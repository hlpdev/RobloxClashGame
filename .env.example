# Logging
LOG_LEVEL=info
LOG_FILE=/app/logs/server_%Y-%m-%d_%H.log

# PostgreSQL
POSTGRES_USER=server
POSTGRES_PASSWORD=changeme
POSTGRES_DB=server

# Connection strings
DATABASE_CONNECTION=host=postgres port=5432 dbname=server user=server password=changeme
REDIS_CONNECTION=redis:6379

# Authentication Secrets
ROBLOX_SERVER_SECRET=changeme
ADMIN_PORTAL_SECRET=changeme

# API Keys
ROBLOX_API_KEY=changeme

# pgAdmin (development only)
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=changeme

# ngrok (development only)
NGROK_AUTHTOKEN=changeme
NGROK_DOMAIN=changeme.ngrok-free.app
